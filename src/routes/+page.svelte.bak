<script>
  import { onMount } from 'svelte';
  
  let tasks = $state([]);
  let showModal = $state(false);
  let loading = $state(true);
  let isDark = $state(false);
  let availableTags = $state([]);
  
  let newTaskTitle = '';
  let newTaskDescription = '';
  let newTaskType = 'task';
  let newTaskAcceptanceCriteria = [''];
  let newTaskTagInput = '';
  let tagSuggestions = $state([]);
  let selectedTags = $state([]);
  
  const taskTypes = [
    { value: 'task', icon: '📝', label: 'Task' },
    { value: 'bug', icon: '🐛', label: 'Bug' },
    { value: 'feature', icon: '✨', label: 'Feature' },
    { value: 'refactor', icon: '🔄', label: 'Refactor' },
    { value: 'test', icon: '🧪', label: 'Test' },
    { value: 'deploy', icon: '🚀', label: 'Deploy' },
    { value: 'review', icon: '👁', label: 'Review' },
    { value: 'docs', icon: '📚', label: 'Documentation' },
    { value: 'database', icon: '🗄️', label: 'Database' },
    { value: 'optimization', icon: '⚡', label: 'Optimization' },
    { value: 'design', icon: '🎨', label: 'Design' },
    { value: 'security', icon: '🔒', label: 'Security' },
    { value: 'devops', icon: '⚙️', label: 'DevOps' }
  ];
  
  $: currentTypeIcon = taskTypes.find(t => t.value === newTaskType)?.icon || '📝';
  
  function toggleDarkMode() {
    isDark = !isDark;
    if (isDark) {
      document.documentElement.classList.add('dark');
      document.documentElement.style.setProperty('--color-background-light', '#121212');
      document.documentElement.style.setProperty('--color-grid-line-light', '#333333');
      document.documentElement.style.setProperty('--color-background-dark', '#121212');
      document.documentElement.style.setProperty('--color-grid-line-dark', '#333333');
      document.body.style.backgroundColor = '#121212';
      document.body.style.color = '#e5e5e5';
    } else {
      document.documentElement.classList.remove('dark');
      document.documentElement.style.removeProperty('--color-background-light');
      document.documentElement.style.removeProperty('--color-grid-line-light');
      document.documentElement.style.removeProperty('--color-background-dark');
      document.documentElement.style.removeProperty('--color-grid-line-dark');
      document.body.style.backgroundColor = '#ffffff';
      document.body.style.color = '#000000';
    }
  }
  
  async function loadTasks() {
    try {
      const response = await fetch('/api/tasks');
      if (response.ok) {
        const data = await response.json();
        tasks = data.tasks || [];
        availableTags = data.tags || [];
      }
    } catch (error) {
      console.error('Error loading tasks:', error);
    } finally {
      loading = false;
    }
  }
  
  async function loadTags() {
    try {
      const response = await fetch('/api/tags');
      if (response.ok) {
        availableTags = await response.json();
      }
    } catch (error) {
      console.error('Error loading tags:', error);
    }
  }
  
  function handleTagInput() {
    const input = newTaskTagInput.toLowerCase().trim();
    if (input.length > 0) {
      tagSuggestions = availableTags.filter(tag => 
        tag.toLowerCase().includes(input) && !selectedTags.includes(tag)
      ).slice(0, 5);
    } else {
      tagSuggestions = [];
    }
  }
  
  function addTag(tag) {
    if (!selectedTags.includes(tag)) {
      selectedTags = [...selectedTags, tag];
      newTaskTagInput = '';
      tagSuggestions = [];
    }
  }
  
  function addNewTag() {
    const tag = newTaskTagInput.trim();
    if (tag && !selectedTags.includes(tag)) {
      selectedTags = [...selectedTags, tag];
      newTaskTagInput = '';
      tagSuggestions = [];
    }
  }
  
  function removeTag(tag) {
    selectedTags = selectedTags.filter(t => t !== tag);
  }
  
  function addAcceptanceCriteria() {
    newTaskAcceptanceCriteria = [...newTaskAcceptanceCriteria, ''];
  }
  
  function removeAcceptanceCriteria(index) {
    newTaskAcceptanceCriteria = newTaskAcceptanceCriteria.filter((_, i) => i !== index);
  }
  
  function updateAcceptanceCriteria(index, value) {
    newTaskAcceptanceCriteria[index] = value;
  }
  
  async function handleAddTask() {
    try {
      const criteria = newTaskAcceptanceCriteria.filter(c => c.trim() !== '');
      const response = await fetch('/api/tasks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          title: newTaskTitle, 
          description: newTaskDescription, 
          type: newTaskType,
          acceptance_criteria: criteria,
          tags: selectedTags
        })
      });
      
      if (response.ok) {
        await loadTasks();
        await loadTags();
        resetModal();
        showModal = false;
      }
    } catch (error) {
      console.error('Error creating task:', error);
    }
  }
  
  async function handleDeleteTask(id) {
    try {
      const response = await fetch(`/api/tasks/${id}`, {
        method: 'DELETE'
      });
      
      if (response.ok) {
        await loadTasks();
      }
    } catch (error) {
      console.error('Error deleting task:', error);
    }
  }
  
  function handleOpenModal() {
    showModal = true;
  }
  
  function handleCloseModal() {
    showModal = false;
    resetModal();
  }
  
  function resetModal() {
    newTaskTitle = '';
    newTaskDescription = '';
    newTaskType = 'task';
    newTaskAcceptanceCriteria = [''];
    newTaskTagInput = '';
    selectedTags = [];
    tagSuggestions = [];
  }
  
  onMount(() => {
    loadTasks();
    loadTags();
    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
      isDark = true;
      toggleDarkMode();
    }
  });
</script>

<div class="fixed top-6 left-6 z-50">
  <button 
    onclick={toggleDarkMode}
    class="bg-background-light border border-primary p-2 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-y-1 hover:translate-x-1 hover:shadow-none transition-all duration-150 text-xl"
    title="Toggle dark mode"
  >
    {isDark ? '☀️' : '🌙'}
  </button>
</div>

<main class="w-full min-h-screen p-1 bg-grid-line-light dark:bg-grid-line-dark transition-colors duration-300">
  <div class="brutalist-grid bg-grid-line-light dark:bg-grid-line-dark">
    {#if loading}
      <div class="col-span-full flex items-center justify-center p-8">
        <p class="text-xs">Loading tasks...</p>
      </div>
    {:else}
      {#each tasks as task, index (task.id)}
        <div 
          class="bg-background-light dark:bg-background-dark aspect-square p-1.5 text-[0.55rem] leading-tight flex flex-col justify-start hover:bg-gray-50 dark:hover:bg-zinc-900 transition-colors group cursor-pointer overflow-hidden"
          oncontextmenu={(e) => { e.preventDefault(); handleDeleteTask(task.id); }}
        >
          <div class="flex items-center gap-1 mb-0.5 opacity-30 group-hover:opacity-100 transition-opacity">
            <span class="text-[0.5rem]">{(index + 1).toString().padStart(2, '0')}</span>
            <span class="text-lg">{taskTypes.find(t => t.value === task.type)?.icon || '📝'}</span>
          </div>
          <p class="font-bold line-clamp-4">{task.title}</p>
          {#if task.tags && task.tags.length > 0}
            <div class="flex flex-wrap gap-0.5 mt-auto pt-0.5">
              {#each task.tags as tag}
                <span class="text-[0.45rem] px-1 bg-gray-200 dark:bg-zinc-700 rounded">{tag}</span>
              {/each}
            </div>
          {/if}
        </div>
      {/each}
      
      <button
        class="bg-background-light dark:bg-background-dark aspect-square p-2 flex flex-col items-center justify-center cursor-pointer hover:bg-gray-100 dark:hover:bg-zinc-900 transition-colors group relative overflow-hidden"
        onclick={handleOpenModal}
      >
        <span class="text-3xl text-gray-400 group-hover:text-primary dark:group-hover:text-white transition-colors">➕</span>
        <span class="mt-1 text-[0.45rem] font-bold uppercase tracking-widest border-b border-primary dark:border-white pb-0.5">New Entry</span>
      </button>
    {/if}
  </div>
  
  <div class="fixed bottom-0 left-0 w-full bg-primary dark:bg-white text-white dark:text-black text-[0.5rem] p-1 font-mono uppercase tracking-widest flex justify-between z-40">
    <span>System Status: Online</span>
    <span>Grid: High Density</span>
    <span>V 2.3.0</span>
  </div>
</main>

{#if showModal}
  <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" onclick={handleCloseModal}>
    <div 
      class="bg-background-light dark:bg-background-dark p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,0.5)] w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto"
      onclick={(e) => e.stopPropagation()}
    >
      <div class="flex justify-between items-start mb-4">
        <h2 class="text-base font-bold uppercase tracking-wider">New Task</h2>
        <button onclick={handleCloseModal} class="p-1 hover:bg-gray-100 dark:hover:bg-zinc-800 rounded text-xl">
          ✕
        </button>
      </div>
      
      <form onsubmit={(e) => { e.preventDefault(); handleAddTask(); }} class="space-y-4">
        <div>
          <label class="block text-[0.6rem] font-bold uppercase mb-2">Title</label>
          <input 
            type="text" 
            bind:value={newTaskTitle}
            required
            class="w-full p-2 border-2 border-primary dark:border-gray-400 bg-transparent font-mono text-xs focus:outline-none focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] dark:focus:shadow-[2px_2px_0px_0px_rgba(255,255,255,0.5)]"
            placeholder="Task title..."
          />
        </div>
        
        <div>
          <label class="block text-[0.6rem] font-bold uppercase mb-2">Description</label>
          <textarea 
            bind:value={newTaskDescription}
            rows="3"
            class="w-full p-2 border-2 border-primary dark:border-gray-400 bg-transparent font-mono text-xs focus:outline-none focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] dark:focus:shadow-[2px_2px_0px_0px_rgba(255,255,255,0.5)]"
            placeholder="Task description..."
          ></textarea>
        </div>
        
        <div>
          <label class="block text-[0.6rem] font-bold uppercase mb-2">Type</label>
          <div class="flex flex-wrap gap-1">
            {#each taskTypes as typeInfo}
              <button
                type="button"
                class="p-2 border-2 {newTaskType === typeInfo.value ? 'bg-primary text-white dark:text-black' : 'border-primary dark:border-gray-400'} text-xs font-bold uppercase transition-all hover:translate-y-0.5 hover:translate-x-0.5 hover:shadow-none flex items-center gap-1"
                onclick={() => newTaskType = typeInfo.value}
              >
                <span class="text-lg">{typeInfo.icon}</span>
                <span class="hidden sm:inline">{typeInfo.label}</span>
              </button>
            {/each}
          </div>
        </div>
        
        <div>
          <div class="flex justify-between items-center mb-2">
            <label class="block text-[0.6rem] font-bold uppercase">Acceptance Criteria</label>
            <button
              type="button"
              onclick={addAcceptanceCriteria}
              class="text-[0.6rem] font-bold uppercase border-2 border-primary dark:border-gray-400 px-2 py-1 hover:bg-gray-100 dark:hover:bg-zinc-800 transition-all flex items-center gap-1"
            >
              ➕ Add
            </button>
          </div>
          <div class="space-y-2">
            {#each newTaskAcceptanceCriteria as criterion, index (index)}
              <div class="flex gap-2">
                <input
                  type="text"
                  bind:value={criterion}
                  placeholder="Criterion {index + 1}..."
                  class="flex-1 p-1.5 border-2 border-primary dark:border-gray-400 bg-transparent font-mono text-[0.6rem] focus:outline-none focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] dark:focus:shadow-[2px_2px_0px_0px_rgba(255,255,255,0.5)]"
                />
                {#if newTaskAcceptanceCriteria.length > 1}
                  <button
                    type="button"
                    onclick={() => removeAcceptanceCriteria(index)}
                    class="p-1.5 border-2 border-red-600 text-red-600 hover:bg-red-600 hover:text-white transition-all text-sm"
                  >
                    ✕
                  </button>
                {/if}
              </div>
            {/each}
          </div>
        </div>
        
        <div>
          <label class="block text-[0.6rem] font-bold uppercase mb-2">Tags</label>
          <div class="relative">
            <input
              type="text"
              bind:value={newTaskTagInput}
              oninput={handleTagInput}
              onkeydown={(e) => {
                if (e.key === 'Enter') {
                  e.preventDefault();
                  addNewTag();
                }
              }}
              placeholder="Add tags..."
              class="w-full p-2 border-2 border-primary dark:border-gray-400 bg-transparent font-mono text-xs focus:outline-none focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] dark:focus:shadow-[2px_2px_0px_0px_rgba(255,255,255,0.5)]"
            />
            {#if tagSuggestions.length > 0}
              <div class="absolute top-full left-0 right-0 mt-1 bg-background-light dark:bg-background-dark border-2 border-primary dark:border-gray-400 z-10 max-h-40 overflow-y-auto">
                {#each tagSuggestions as suggestion}
                  <button
                    type="button"
                    onclick={() => addTag(suggestion)}
                    class="w-full text-left p-2 text-[0.6rem] hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
                  >
                    {suggestion}
                  </button>
                {/each}
              </div>
            {/if}
          </div>
          {#if selectedTags.length > 0}
            <div class="flex flex-wrap gap-1 mt-2">
              {#each selectedTags as tag}
                <span class="inline-flex items-center gap-1 px-2 py-1 bg-primary dark:bg-white text-white dark:text-black text-[0.55rem]">
                  {tag}
                  <button
                    type="button"
                    onclick={() => removeTag(tag)}
                    class="hover:bg-gray-200 dark:hover:bg-zinc-800 rounded p-0.5 transition-colors text-sm"
                  >
                    ✕
                  </button>
                </span>
              {/each}
            </div>
          {/if}
        </div>
        
        <div class="flex gap-2 pt-2">
          <button 
            type="submit"
            class="flex-1 bg-primary dark:bg-white text-white dark:text-black py-2 px-4 font-bold uppercase text-xs hover:translate-y-0.5 hover:translate-x-0.5 hover:shadow-none transition-all shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] dark:shadow-[2px_2px_0px_0px_rgba(255,255,255,0.5)]"
          >
            Create Task
          </button>
          <button 
            type="button"
            onclick={handleCloseModal}
            class="flex-1 bg-transparent border-2 border-primary dark:border-gray-400 py-2 px-4 font-bold uppercase text-xs hover:bg-gray-100 dark:hover:bg-zinc-800 transition-all"
          >
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>
{/if}

<style>
  .brutalist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
  }
  
  @media (min-width: 640px) {
    .brutalist-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  @media (min-width: 768px) {
    .brutalist-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .brutalist-grid {
      grid-template-columns: repeat(12, 1fr);
    }
  }
</style>
